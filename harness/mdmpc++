#!/usr/bin/env bash
# mdmpc++ : The MDMP C++ Compiler Wrapper

set -euo pipefail

MDMP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

CXX_BIN="${MDMP_CXX:-clang++}"

PLUGIN_PATH="${MDMP_DIR}/../build/src/MDMP.so"
SRC_DIR="${MDMP_DIR}/../src"
RUNTIME_DIR="${MDMP_DIR}/../build/src"

if [[ ! -f "${PLUGIN_PATH}" ]]; then
  echo "mdmpc++ error: MDMP pass plugin not found at ${PLUGIN_PATH}" >&2
  exit 1
fi

PLUGIN_ARGS=( "-fpass-plugin=${PLUGIN_PATH}" )
INCLUDE_ARGS=( "-I${SRC_DIR}" )
LINK_ARGS=( "-Wl,--no-as-needed" "-L${RUNTIME_DIR}" "-Wl,-rpath,${RUNTIME_DIR}" "-lmdmp_runtime" )

compile_only=0
preprocess_only=0
assemble_only=0
has_source=0
saw_opt=0
show_cmd=0  # NEW: Toggle for printing the command

USER_ARGS=()

for arg in "$@"; do
  case "${arg}" in
    --mdmp-show)
      # Intercept our custom flag, set the toggle, and do NOT add it to USER_ARGS
      show_cmd=1
      ;;
    -c)
      compile_only=1
      USER_ARGS+=( "${arg}" )
      ;;
    -E)
      preprocess_only=1
      USER_ARGS+=( "${arg}" )
      ;;
    -S)
      assemble_only=1
      USER_ARGS+=( "${arg}" )
      ;;
    *.cc|*.cpp|*.cxx|*.C|*.CPP)
      has_source=1
      USER_ARGS+=( "${arg}" )
      ;;
    -O0)
      saw_opt=1
      USER_ARGS+=( "-O1" "-flto" )
      ;;
    -O|-O1|-O2|-O3|-Ofast|-Og|-Os|-Oz)
      saw_opt=1
      USER_ARGS+=( "${arg}" "-flto" )
      ;;
    *)
      USER_ARGS+=( "${arg}" )
      ;;
  esac
done

if (( ! saw_opt )); then
  USER_ARGS=( "-O1" "-flto" "${USER_ARGS[@]}" )
fi

LTO_LINK_ARGS=()
for arg in "${USER_ARGS[@]}"; do
  if [[ "${arg}" == "-flto"* ]]; then
    LTO_LINK_ARGS=( "-fuse-ld=lld" "-Wl,--load-pass-plugin=${PLUGIN_PATH}" )
    break
  fi
done

# Helper function to print and execute
execute() {
  if (( show_cmd )); then
    echo -e "\033[1;36m[mdmpc++]\033[0m Executing:" >&2
    printf '%q ' "$@" >&2
    echo >&2
  fi
  exec "$@"
}

# Preprocess only
if (( preprocess_only )); then
  execute "${CXX_BIN}" "${INCLUDE_ARGS[@]}" "${USER_ARGS[@]}"
fi

# Compile-only or assembly-only
if (( compile_only || assemble_only )); then
  execute "${CXX_BIN}" "${PLUGIN_ARGS[@]}" "${INCLUDE_ARGS[@]}" "${USER_ARGS[@]}"
fi

# Compile + Link in one step
if (( has_source )); then
  execute "${CXX_BIN}" "${PLUGIN_ARGS[@]}" "${INCLUDE_ARGS[@]}" "${USER_ARGS[@]}" "${LINK_ARGS[@]}" "${LTO_LINK_ARGS[@]}"
fi

# Link-only step
execute "${CXX_BIN}" "${PLUGIN_ARGS[@]}" "${USER_ARGS[@]}" "${LINK_ARGS[@]}" "${LTO_LINK_ARGS[@]}"
