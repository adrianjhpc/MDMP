#!/usr/bin/env bash
# mdmpc : The MDMP C Compiler Wrapper

set -euo pipefail

MDMP_DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"

CC_BIN="${MDMP_CC:-clang}"

PLUGIN_PATH="${MDMP_DIR}/../build/src/MDMP.so"
SRC_DIR="${MDMP_DIR}/../src"
RUNTIME_DIR="${MDMP_DIR}/../build/src"

if [[ ! -f "${PLUGIN_PATH}" ]]; then
  echo "mdmpc error: MDMP pass plugin not found at ${PLUGIN_PATH}" >&2
  exit 1
fi

PLUGIN_ARGS=( "-fpass-plugin=${PLUGIN_PATH}" )
INCLUDE_ARGS=( "-I${SRC_DIR}" )
LINK_ARGS=( "-L${RUNTIME_DIR}" "-Wl,-rpath,${RUNTIME_DIR}" "-lmdmp_runtime" )

compile_only=0
preprocess_only=0
assemble_only=0
has_source=0
saw_opt=0
show_cmd=0  # NEW: Toggle for printing the command

USER_ARGS=()

for arg in "$@"; do
  case "${arg}" in
    --mdmp-show)
      # Intercept our custom flag, set the toggle, and do NOT add it to USER_ARGS
      show_cmd=1
      ;;
    -c)
      compile_only=1
      USER_ARGS+=( "${arg}" )
      ;;
    -E)
      preprocess_only=1
      USER_ARGS+=( "${arg}" )
      ;;
    -S)
      assemble_only=1
      USER_ARGS+=( "${arg}" )
      ;;
    *.c)
      has_source=1
      USER_ARGS+=( "${arg}" )
      ;;
    -O0)
      saw_opt=1
      USER_ARGS+=( "-O1" "-flto" )
      ;;
    -O|-O1|-O2|-O3|-Ofast|-Og|-Os|-Oz)
      saw_opt=1
      USER_ARGS+=( "${arg}" "-flto" )
      ;;
    *)
      USER_ARGS+=( "${arg}" )
      ;;
  esac
done

# If the user supplied no optimisation flag, enforce the minimum needed.
if (( ! saw_opt )); then
  USER_ARGS=( "-O1" "-flto" "${USER_ARGS[@]}" )
fi

execute() {
  if (( show_cmd )); then
    echo -e "\033[1;36m[mdmpc]\033[0m Executing:" >&2
    printf '%q ' "$@" >&2
    echo >&2
  fi
  exec "$@"
}

if (( preprocess_only )); then
  execute "${CC_BIN}" "${INCLUDE_ARGS[@]}" "${USER_ARGS[@]}"
fi

if (( compile_only || assemble_only )); then
  execute "${CC_BIN}" "${PLUGIN_ARGS[@]}" "${INCLUDE_ARGS[@]}" "${USER_ARGS[@]}"
fi

if (( has_source )); then
  execute "${CC_BIN}" "${PLUGIN_ARGS[@]}" "${INCLUDE_ARGS[@]}" "${USER_ARGS[@]}" "${LINK_ARGS[@]}"
fi

execute "${CC_BIN}" "${PLUGIN_ARGS[@]}" "${USER_ARGS[@]}" "${LINK_ARGS[@]}"
